rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function listData(listId) {
      return get(/databases/$(database)/documents/shoppingLists/$(listId)).data;
    }

    function isListMember(listId) {
      return isSignedIn() && request.auth.uid in listData(listId).members;
    }

    function isListMemberFromData(list) {
      return isSignedIn() && request.auth.uid in list.members;
    }

    function isOwner(list, uid) {
      return uid in list.members && list.memberRoles[uid] == 'owner';
    }

    function isEditor(list, uid) {
      return uid in list.members && list.memberRoles[uid] == 'editor';
    }

    function isViewer(list, uid) {
      return uid in list.members && list.memberRoles[uid] == 'viewer';
    }

    function canEditItems(list, uid) {
      return isOwner(list, uid) || isEditor(list, uid);
    }

    function canManageMembers(list, uid) {
      return isOwner(list, uid);
    }

    function canDeleteList(list, uid) {
      return isOwner(list, uid);
    }

    function keepsListOwnerStable() {
      return request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.ownerName == resource.data.ownerName;
    }

    function keepsListMembersStable() {
      return request.resource.data.members == resource.data.members
        && request.resource.data.memberRoles == resource.data.memberRoles;
    }

    function onlyUpdatesItemCounts() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'totalItems',
        'completedItems',
        'updatedAt',
      ]);
    }

    function hasValidMemberData(data) {
      return data.members is list
        && data.memberRoles is map
        && data.ownerId in data.members
        && data.memberRoles[data.ownerId] == 'owner'
        && data.memberRoles.keys().hasAll(data.members)
        && data.memberRoles.keys().hasOnly(data.members)
        && data.memberRoles.values().hasOnly(['owner', 'editor', 'viewer']);
    }

    match /users/{userId} {
      allow read: if isSignedIn();

      allow create: if isUser(userId)
        && request.resource.data.uid == userId;

      allow update: if isUser(userId)
        && request.resource.data.uid == resource.data.uid;

      allow delete: if false;
    }

    match /shoppingLists/{listId} {
      allow read: if isListMemberFromData(resource.data);

      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.members
        && request.resource.data.memberRoles[request.auth.uid] == 'owner'
        && hasValidMemberData(request.resource.data);

      allow update: if (
          isSignedIn()
          && canManageMembers(resource.data, request.auth.uid)
          && keepsListOwnerStable()
          && hasValidMemberData(request.resource.data)
        )
        || (
          isSignedIn()
          && canEditItems(resource.data, request.auth.uid)
          && keepsListOwnerStable()
          && keepsListMembersStable()
          && onlyUpdatesItemCounts()
        );

      allow delete: if isSignedIn()
        && canDeleteList(resource.data, request.auth.uid);

      match /items/{itemId} {
        allow read: if isListMember(listId);
        allow create, update, delete: if isSignedIn()
          && canEditItems(listData(listId), request.auth.uid);
      }
    }
  }
}
